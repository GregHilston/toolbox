# Secret env vars are generated from 1Password templates.
# Run `just secrets` to generate secrets/.env, then direnv loads it here.
#
# To set up from scratch:
#   1. Install 1Password CLI: brew install 1password-cli
#   2. Sign in: op signin
#   3. Generate secrets: just secrets
#   4. Allow direnv: direnv allow

dotenv_if_exists secrets/.env
